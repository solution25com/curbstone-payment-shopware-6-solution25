<?xml version="1.0"?>
<container xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />
        <service id="Curbstone.logger" class="Monolog\Logger">
            <argument type="string">Curbstone</argument>
            <argument type="collection">
                <argument type="service" id="Curbstone.rotatingHandler"/>
            </argument>
        </service>
        <service id="Curbstone.rotatingHandler" class="Monolog\Handler\RotatingFileHandler">
            <argument type="string">%kernel.logs_dir%/Curbstone-%kernel.environment%.log</argument>
            <argument type="constant">Monolog\Logger::INFO</argument>
        </service>
        <!-- Services -->
    <service id="Curbstone\Service\CurbstoneRequestFactory" />
    <service id="Curbstone\Service\CurbstoneRefundService">
        <argument type="service" id="Curbstone\Config\CurbstoneConfigProvider"/>
        <argument type="service" id="Curbstone\Service\CurbstoneTransactionService"/>
        <argument type="service" id="Curbstone\Service\CurbstonePaymentClient"/>
        <argument type="service" id="Curbstone\Service\CurbstoneRequestFactory"/>
        <argument type="service" id="order_transaction_capture_refund.repository"/>
        <argument type="service" id="Curbstone.logger"/>
    </service>


        <service id="Curbstone\Service\CurbstoneCardResolver">
            <argument type="service" id="monolog.logger" />
            <argument type="service" id="Curbstone\Service\CurbstoneVaultService" />
        </service>

        <service id="Curbstone\Service\CurbstonePaymentClient" />
        <service id="Curbstone\Service\CurbstonePreauthClient" public="false" />
        
        <service id="Curbstone\Service\CurbstoneVaultService" public="false">
            <argument type="service" id="customer.repository" />
            <argument type="service" id="Curbstone.logger" />
        </service>
        <!-- Config provider (reads SystemConfig + env) -->
        <service id="Curbstone\Config\CurbstoneConfigProvider">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
        </service>

        <service id="Curbstone\Service\CurbstoneTransactionService" public="false">
            <argument type="service" id="Shopware\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler" />
            <argument type="service" id="order_transaction.repository" />
            <argument type="service" id="router" />
            <argument type="service" id="Curbstone.logger" />
        </service>
        

        <!-- Gateways facade (typed DTO in/out) -->
        <service id="Curbstone\Gateways\CreditCard" public="true">
            <argument type="service" id="Shopware\Core\Checkout\Order\Aggregate\OrderTransaction\OrderTransactionStateHandler" />
            <argument type="service" id="Curbstone\Config\CurbstoneConfigProvider" />
            <argument type="service" id="Curbstone.logger" />
            <argument type="service" id="Curbstone\Service\CurbstoneRequestFactory" />
            <argument type="service" id="Curbstone\Service\CurbstoneCardResolver" />
            <argument type="service" id="Curbstone\Service\CurbstonePaymentClient" />
            <argument type="service" id="Curbstone\Service\CurbstoneTransactionService" />
        </service>

        <service id="Curbstone\Subscriber\CheckoutConfirmEventSubscriber">
            <tag name="kernel.event_subscriber" />
        </service>
        <service id="Curbstone\Subscriber\CurbstoneRefundSubscriber">
            <argument type="service" id="Curbstone\Config\CurbstoneConfigProvider" />
            <argument type="service" id="Curbstone\Service\CurbstoneTransactionService" />
            <argument type="service" id="Curbstone\Service\CurbstoneRefundService" />
            <argument type="service" id="Curbstone.logger" />
            <tag name="kernel.event_subscriber" />
        </service>


        <service id="Curbstone\Storefront\Controller\CurbstoneInlinePreauthController" public="true">
            <argument type="service" id="Curbstone\Config\CurbstoneConfigProvider" />
            <argument type="service" id="Curbstone.logger" />
            <argument type="service" id="Curbstone\Service\CurbstoneRequestFactory" />
            <argument type="service" id="Curbstone\Service\CurbstonePreauthClient" />
            <argument type="service" id="Curbstone\Service\CurbstoneVaultService" />
            <argument type="string">%kernel.environment%</argument>
            <tag name="controller.service_arguments" />
        </service>

        <service id="Curbstone\Storefront\Controller\SavedCardsController" public="true">
            <argument type="service" id="Shopware\Storefront\Page\GenericPageLoader" />
        </service>
        <service id="Curbstone\Command\BackfillSavedCardMetadataCommand" public="true">
            <tag name="console.command" />
        </service>
        <service id="Curbstone\Service\CustomFieldUpdater"
            class="Curbstone\Service\CustomFieldUpdater" public="false">
            <argument type="service" id="order_transaction.repository" />
            <argument type="service" id="order.repository" />
        </service>

    </services>
</container>
